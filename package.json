{
  "name": "scribe",
  "version": "0.1.0",
  "private": true,
  "description": "Collaborative writing editor sourcing raw notebook prose from Gloss.",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,magenta \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "node --watch server.js",
    "dev:web": "vite",
    "build": "vite build",
    "start": "NODE_ENV=production node server.js",
    "test": "node --test tests/*.test.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@hocuspocus/server": "^2.15.0",
    "better-sqlite3": "^11.3.0",
    "cookie": "^1.0.1",
    "express": "^4.21.1",
    "nanoid": "^5.0.7",
    "ws": "^8.18.0",
    "yjs": "^13.6.20"
  },
  "devDependencies": {
    "@hocuspocus/provider": "^2.15.0",
    "@tiptap/core": "^2.8.0",
    "@tiptap/extension-collaboration": "^2.8.0",
    "@tiptap/extension-collaboration-cursor": "^2.8.0",
    "@tiptap/extension-link": "^2.8.0",
    "@tiptap/extension-placeholder": "^2.8.0",
    "@tiptap/pm": "^2.8.0",
    "@tiptap/react": "^2.8.0",
    "@tiptap/starter-kit": "^2.8.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "tiptap-markdown": "^0.8.10",
    "vite": "^5.4.10",
    "y-protocols": "^1.0.6"
  },
  "engines": {
    "node": ">=20"
  }
}

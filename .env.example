PORT=3748
NODE_ENV=development

# Owner auth (required in prod). Unset in dev = open on localhost.
AUTH_PASSWORD=
SESSION_SECRET=

# Default owner identity for docs created without a session (dev convenience).
SCRIBE_OWNER_EMAIL=nathan@local

# Gloss service connection. GLOSS_API_KEY matches Gloss's API_KEY env var
# (bearer token Gloss accepts on /api/* routes).
GLOSS_URL=http://localhost:3747
GLOSS_API_KEY=

# Gemini AI.
GEMINI_API_KEY=

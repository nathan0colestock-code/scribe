PORT=3748
NODE_ENV=development

# Owner auth (required in prod). Unset in dev = open on localhost.
AUTH_PASSWORD=
SESSION_SECRET=

# Default owner identity for docs created without a session (dev convenience).
SCRIBE_OWNER_EMAIL=nathan@local

# Gloss service connection. GLOSS_API_KEY matches Gloss's API_KEY env var
# (bearer token Gloss accepts on /api/* routes).
GLOSS_URL=http://localhost:3747
GLOSS_API_KEY=

# Comms outbound (Review → "Send to Comms as draft" flow).
COMMS_URL=http://localhost:3748
COMMS_API_KEY=

# Black-hole archive search. Used by the Archive tab in the reference panel
# (GET /api/documents/:id/black-suggestions) to surface archived files that
# match the current document's topic/people signal. Unset = Archive tab
# quietly shows no results.
BLACK_URL=http://localhost:3749
BLACK_API_KEY=

# Gemini AI.
GEMINI_API_KEY=
